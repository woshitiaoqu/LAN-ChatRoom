{
  "name": "lan-chat-server",
  "version": "1.1.0",
  "description": "LAN ChatRoom - 服务端桌面应用",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "lan.chatroom.server",
    "productName": "LAN Chat 服务端",
    "directories": {
      "output": "../dist/server-setup"
    },
    "asar": false,
    "electronDist": "../client/node_modules/electron/dist",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LAN Chat 服务端",
      "language": "2052"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  }
}
