{
  "name": "lan-chat-client",
  "version": "1.1.0",
  "description": "LAN ChatRoom - ň«óŠłĚšź»",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "lan.chatroom.client",
    "productName": "LAN Chat ň«óŠłĚšź»",
    "directories": {
      "output": "../dist/client-setup"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css"
    ],
    "electronDist": "node_modules/electron/dist",
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LAN Chat ň«óŠłĚšź»",
      "language": "2052"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  }
}