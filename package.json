{
  "name": "lan-chat",
  "version": "1.1.0",
  "description": "局域网聊天室 - 服务端",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "admin": "node adminConsole.js",
    "build:server": "pkg server.js --targets node18-win-x64 --output dist/LANChat-Server.exe",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:server && npm run build:client"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/lib/binding/**/*",
      "uploads/**/*",
      "games/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.22.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.21.0"
  }
}
